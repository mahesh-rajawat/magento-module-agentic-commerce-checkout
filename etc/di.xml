<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Service contract bindings -->
    <preference for="MSR\AgenticUcpCheckout\Api\UcpCatalogInterface"
                type="MSR\AgenticUcpCheckout\Model\UcpCatalog"/>

    <preference for="MSR\AgenticUcpCheckout\Api\UcpCartInterface"
                type="MSR\AgenticUcpCheckout\Model\UcpCart"/>

    <preference for="MSR\AgenticUcpCheckout\Api\UcpCheckoutInterface"
                type="MSR\AgenticUcpCheckout\Model\UcpCheckout"/>

    <preference for="MSR\AgenticUcpCheckout\Api\UcpOrderInterface"
                type="MSR\AgenticUcpCheckout\Model\UcpOrder"/>

    <preference for="MSR\AgenticUcpCheckout\Api\UcpInventoryInterface"
                type="MSR\AgenticUcpCheckout\Model\UcpInventory"/>

    <!-- Data object bindings -->
    <preference for="MSR\AgenticUcpCheckout\Api\Data\CartItemInterface"
                type="MSR\AgenticUcpCheckout\Model\Data\CartItem"/>

    <preference for="MSR\AgenticUcpCheckout\Api\Data\ShippingAddressInterface"
                type="MSR\AgenticUcpCheckout\Model\Data\ShippingAddress"/>

    <preference for="MSR\AgenticUcpCheckout\Api\Data\OrderResultInterface"
                type="MSR\AgenticUcpCheckout\Model\Data\OrderResult"/>

    <preference for="MSR\AgenticUcpCheckout\Api\Data\CartSummaryInterface"
                type="MSR\AgenticUcpCheckout\Model\Data\CartSummary"/>
    <type name="MSR\AgenticUcp\Controller\Wellknown\Index">
        <arguments>
            <argument name="capabilities" xsi:type="array">
                <item name="dev_ucp_shopping_catalog" xsi:type="array">
                    <item name="id" xsi:type="string">dev.ucp.shopping.catalog</item>
                    <item name="config" xsi:type="array">
                        <item name="browse_endpoint"
                              xsi:type="string">/rest/V1/ucp/catalog</item>
                        <item name="search_endpoint"
                              xsi:type="string">/rest/V1/ucp/search</item>
                        <item name="inventory_endpoint"
                              xsi:type="string">/rest/V1/ucp/inventory</item>
                    </item>
                </item>
                <item name="dev_ucp_shopping_checkout" xsi:type="array">
                    <item name="id" xsi:type="string">dev.ucp.shopping.checkout</item>
                    <item name="extends" xsi:type="string">dev.ucp.shopping.catalog</item>
                    <item name="config"  xsi:type="array">
                        <item name="cart_endpoint"
                              xsi:type="string">/rest/V1/ucp/cart</item>
                        <item name="shipping_endpoint"
                              xsi:type="string">/rest/V1/ucp/checkout/shipping</item>
                        <item name="billing_endpoint"
                              xsi:type="string">/rest/V1/ucp/checkout/billing</item>
                    </item>
                </item>

                <item name="dev_ucp_shopping_order" xsi:type="array">
                    <item name="id" xsi:type="string">dev.ucp.shopping.order</item>
                    <item name="extends" xsi:type="string">dev.ucp.shopping.checkout</item>
                    <item name="config" xsi:type="array">
                        <item name="order_endpoint"
                              xsi:type="string">/rest/V1/ucp/order</item>
                    </item>
                </item>

                <item name="dev_ucp_shopping_fulfillment" xsi:type="array">
                    <item name="id" xsi:type="string">dev.ucp.shopping.fulfillment</item>
                    <item name="extends" xsi:type="string">dev.ucp.shopping.order</item>
                    <item name="config"  xsi:type="array">
                        <item name="tracking_endpoint"
                              xsi:type="string">/rest/V1/ucp/order/{id}</item>
                    </item>
                </item>
            </argument>
            <argument name="paymentHandlers" xsi:type="array">
            </argument>
        </arguments>
    </type>

</config>
